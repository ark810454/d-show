<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DShow.PosMobile.Pages.BootstrapPage"
             BackgroundColor="#0f172a">
    <Grid Padding="24">
        <VerticalStackLayout VerticalOptions="Center" Spacing="16">
            <Label Text="D_Show POS Mobile"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="Center" />
            <ActivityIndicator IsRunning="True" Color="#f59e0b" HeightRequest="44" />
            <Label x:Name="StatusLabel"
                   Text="Chargement de la session mobile..."
                   TextColor="#cbd5e1"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
