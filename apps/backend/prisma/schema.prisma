  client            Client?             @relation(fields: [clientId], references: [id], onDelete: SetNull)
  ticket            NightclubEntryTicket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  validatedBy       User?               @relation("NightclubAccessValidatedBy", fields: [validatedByUserId], references: [id], onDelete: SetNull)

  @@index([companyId, activityId, createdAt])
