  serveur         User?                     @relation("NightclubBottleOrderServer", fields: [serverId], references: [id], onDelete: SetNull)
  event           NightclubEvent?           @relation(fields: [eventId], references: [id], onDelete: SetNull)
  items           NightclubBottleOrderItem[]
  payments        NightclubBottlePayment[]

  @@index([companyId, activityId, statut])
