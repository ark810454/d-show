model ShopCategory {
  id          String       @id @default(cuid())
  companyId   String
  activityId  String
  nom         String
  description String?      @db.Text
  actif       Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  activity    Activity     @relation(fields: [activityId], references: [id], onDelete: Cascade)
  produits    ShopProduct[]

  @@unique([activityId, nom])
  @@index([companyId, activityId, actif])
  @@index([deletedAt])
}

model ShopProduct {
  id             String            @id @default(cuid())
  companyId      String
  activityId     String
  categoryId     String?
  sku            String
  codeBarres     String?
  nom            String
  description    String?           @db.Text
  image          String?
  prixVente      Decimal           @db.Decimal(12, 2)
  prixAchat      Decimal?          @db.Decimal(12, 2)
  stockActuel    Int               @default(0)
  stockMinimum   Int               @default(0)
  statut         ShopProductStatus @default(ACTIVE)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?
  company        Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  activity       Activity          @relation(fields: [activityId], references: [id], onDelete: Cascade)
  categorie      ShopCategory?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  promotions     ShopPromotion[]
  saleItems      ShopSaleItem[]
  stockMovements StockMovement[]

  @@unique([activityId, sku])
  @@unique([activityId, codeBarres])
  @@index([companyId, activityId, statut])
  @@index([categoryId])
  @@index([deletedAt])
}

model ShopPromotion {
  id            String      @id @default(cuid())
  companyId     String
  activityId    String
  productId     String
  nom           String
  description   String?     @db.Text
  reductionType String
  reductionValeur Decimal   @db.Decimal(12, 2)
  dateDebut     DateTime
  dateFin       DateTime
  actif         Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  activity      Activity    @relation(fields: [activityId], references: [id], onDelete: Cascade)
  product       ShopProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([companyId, activityId, actif])
  @@index([productId, dateDebut, dateFin])
}

model ShopSale {
  id             String            @id @default(cuid())
  companyId      String
  activityId     String
  clientId       String?
  sellerId       String?
  reference      String            @unique
  statut         ShopSaleStatus    @default(BROUILLON)
  statutPaiement PaymentStatus     @default(IMPAYE)
  modePaiement   PaymentMethod?
  totalHt        Decimal           @default(0) @db.Decimal(12, 2)
  taxeMontant    Decimal           @default(0) @db.Decimal(12, 2)
  totalTtc       Decimal           @db.Decimal(12, 2)
  remise         Decimal           @default(0) @db.Decimal(12, 2)
  note           String?           @db.Text
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?
  company        Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  activity       Activity          @relation(fields: [activityId], references: [id], onDelete: Cascade)
  client         Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  vendeur        User?             @relation("ShopSaleSeller", fields: [sellerId], references: [id], onDelete: SetNull)
  items          ShopSaleItem[]
  transactions   FinancialTransaction[]

  @@index([companyId, activityId, statut])
  @@index([companyId, createdAt])
  @@index([clientId])
  @@index([sellerId])
  @@index([deletedAt])
}

model ShopSaleItem {
  id          String    @id @default(cuid())
  companyId   String
  activityId  String
  shopSaleId  String
  productId   String?
  libelle     String
  quantite    Int       @default(1)
  prixUnitaire Decimal  @db.Decimal(12, 2)
  totalLigne  Decimal   @db.Decimal(12, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  activity    Activity  @relation(fields: [activityId], references: [id], onDelete: Cascade)
  sale        ShopSale  @relation(fields: [shopSaleId], references: [id], onDelete: Cascade)
  produit     ShopProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([companyId, activityId, shopSaleId])
  @@index([productId])
}

model StockMovement {
  id            String            @id @default(cuid())
  companyId     String
  activityId    String
  productId     String
  userId        String?
  typeMouvement StockMovementType
  quantite      Int
  coutUnitaire  Decimal?          @db.Decimal(12, 2)
  reference     String?
  raison        String?
  note          String?           @db.Text
  occuredAt     DateTime          @default(now())
  createdAt     DateTime          @default(now())
  company       Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  activity      Activity          @relation(fields: [activityId], references: [id], onDelete: Cascade)
  product       ShopProduct       @relation(fields: [productId], references: [id], onDelete: Cascade)
  user          User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, activityId, occuredAt])
  @@index([productId, occuredAt])
  @@index([userId, occuredAt])
}

model FinanceAccount {
  id           String       @id @default(cuid())
  companyId    String
  code         String
  nom          String
  description  String?      @db.Text
  actif        Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  transactions FinancialTransaction[]

  @@unique([companyId, code])
  @@index([companyId, actif])
  @@index([deletedAt])
}

model CashRegister {
  id                 String               @id @default(cuid())
  companyId          String
  activityId         String
  code               String
  nom                String
  statut             CashRegisterStatus   @default(FERMEE)
  soldeOuverture     Decimal              @default(0) @db.Decimal(12, 2)
  soldeCourant       Decimal              @default(0) @db.Decimal(12, 2)
  openedAt           DateTime?
  closedAt           DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  deletedAt          DateTime?
  company            Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  activity           Activity             @relation(fields: [activityId], references: [id], onDelete: Cascade)
  transactions       FinancialTransaction[]

  @@unique([activityId, code])
  @@index([companyId, activityId, statut])
  @@index([deletedAt])
}

model FinancialTransaction {
  id                    String                   @id @default(cuid())
  companyId             String
  activityId            String?
  financeAccountId      String?
  cashRegisterId        String?
  userId                String?
  clientId              String?
  restaurantOrderId     String?
  terraceReservationId  String?
  nightclubBookingId    String?
  shopSaleId            String?
  reference             String                   @unique
  typeTransaction       FinancialTransactionType
  modePaiement          PaymentMethod?
  statutPaiement        PaymentStatus            @default(IMPAYE)
  montant               Decimal                  @db.Decimal(12, 2)
  description           String?                  @db.Text
  justificatif          String?
  dateTransaction       DateTime                 @default(now())
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  deletedAt             DateTime?
  company               Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  activity              Activity?                @relation(fields: [activityId], references: [id], onDelete: SetNull)
  financeAccount        FinanceAccount?          @relation(fields: [financeAccountId], references: [id], onDelete: SetNull)
  cashRegister          CashRegister?            @relation(fields: [cashRegisterId], references: [id], onDelete: SetNull)
  user                  User?                    @relation(fields: [userId], references: [id], onDelete: SetNull)
  client                Client?                  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  restaurantOrder       RestaurantOrder?         @relation(fields: [restaurantOrderId], references: [id], onDelete: SetNull)
  terraceReservation    TerraceReservation?      @relation(fields: [terraceReservationId], references: [id], onDelete: SetNull)
  nightclubBooking      NightclubBooking?        @relation(fields: [nightclubBookingId], references: [id], onDelete: SetNull)
  shopSale              ShopSale?                @relation(fields: [shopSaleId], references: [id], onDelete: SetNull)

  @@index([companyId, dateTransaction])
  @@index([activityId, dateTransaction])
  @@index([cashRegisterId, dateTransaction])
  @@index([userId, dateTransaction])
  @@index([statutPaiement, dateTransaction])
  @@index([deletedAt])
}
