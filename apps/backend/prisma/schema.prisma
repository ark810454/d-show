  bottleItem        NightclubBottleItem? @relation(fields: [bottleItemId], references: [id], onDelete: SetNull)

  @@index([companyId, activityId, bottleOrderId])
  @@index([bottleItemId])
}

model NightclubBottlePayment {
  id                String               @id @default(cuid())
  companyId         String
  activityId        String
  bottleOrderId     String
  processedByUserId String?
  reference         String               @unique
  montant           Decimal              @db.Decimal(12, 2)
  modePaiement      PaymentMethod
