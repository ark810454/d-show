  activity    Activity    @relation(fields: [activityId], references: [id], onDelete: Cascade)
  items       NightclubBottleItem[]

  @@unique([activityId, nom])
  @@index([companyId, activityId, actif])
  @@index([deletedAt])
}

model NightclubBottleItem {
  id          String           @id @default(cuid())
  companyId   String
  activityId  String
  categoryId  String
  nom         String
  description String?          @db.Text
